  "provider": {
    "ai-fed": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Local AI Federation",
      "options": {
        "baseURL": "http://localhost:8787/v1"
      },
      "models": {
        "custom/prod": {
          "name": "Custom Production Proxy"
        }
