{
  "name": "@janek26/aimux",
  "version": "0.1.0",
  "description": "One Bun CLI for muxing LLM providers and MCP servers behind local gateways.",
  "type": "module",
  "license": "MIT",
  "packageManager": "bun@1.3.10",
  "repository": {
    "type": "git",
    "url": "https://github.com/janek26/aimux"
  },
  "homepage": "https://github.com/janek26/aimux#readme",
  "bugs": {
    "url": "https://github.com/janek26/aimux/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "bin": {
    "aimux": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    ".aimux.example.yml"
  ],
  "keywords": [
    "ai",
    "llm",
    "mcp",
    "model-context-protocol",
    "cli",
    "gateway",
    "bun",
    "typescript"
  ],
  "scripts": {
    "assert:ci-publish": "node -e \"if (process.env.GITHUB_ACTIONS !== 'true') { console.error('Publishing is only allowed from GitHub Actions via semantic-release.'); process.exit(1); }\"",
    "build": "bun build ./src/cli.ts --compile --outfile aimux",
    "build:npm": "bun build ./src/cli.ts --target=bun --outfile dist/cli.js",
    "check": "bun run typecheck && bun test",
    "prepack": "bun run build:npm",
    "prepublishOnly": "bun run assert:ci-publish && bun run check && bun run build:npm",
    "release": "semantic-release",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "@hyperjump/json-schema": "^1.17.6",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cosmiconfig": "^9.0.1",
    "jsonc-parser": "^3.3.1",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "bun-types": "^1.3.13",
    "semantic-release": "^25.0.3",
    "typescript": "^6.0.3"
  }
}
